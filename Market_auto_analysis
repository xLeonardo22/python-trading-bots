import clr
clr.AddReference("cAlgo.API")
from cAlgo.API import *
from datetime import datetime, timedelta
import math
import traceback


class BotTradingM5():

    # ======================================================
    # INITIALISATION
    # ======================================================
    def on_start(self):
        api.Positions.Closed += self.on_position_closed
        api.Positions.Opened += self.on_position_opened

        self.symbol  = api.Symbol
        self.account = api.Account

        # --- Risk parameters ---
        self.RISK_PCT = 1.0
        if self.symbol.Name.startswith("US"):
            self.RISK_PCT = 0.5

        self.PRICE_SAMPLE_BOOTSTRAP = 2   # seconds between samples during warm-up
        self.PRICE_SAMPLE_NORMAL    = 15  # seconds between samples in normal mode
        self.MIN_PRICES  = 55
        self.MAX_SL_PIPS = 27
        self.sl_min      = 15
        self.rr          = 1.8

        # --- EMA periods ---
        self.periodo_fast = 15
        self.periodo_slow = 35

        # --- State flags ---
        self.pause_bars_remaining = 0
        self.planned_entry_price  = 0
        self.planned_sl_pips      = 0

        # --- Order-lock (prevents double entries) ---
        self.order_lock      = False
        self.last_entry_time = None

        # --- Signal bus: on_bar -> on_tick ---
        self.signal_mode    = None   # "LONG", "SHORT", or None
        self.signal_price   = 0.0
        self.signal_sl_ref  = 0.0

        # --- 15-second price buffer ---
        self.prices_15s     = []
        self.last_sample_ts = api.Server.Time
        self.ready          = False

        # --- Throttled logging ---
        self.last_log_time = api.Server.Time
        self.LOG_INTERVAL  = 8  # seconds between log entries

        # --- Near-TP tracking ---
        self.near_tp_reaches = set()

        # --- Daily stop counter ---
        self.last_stop_reset_day = api.Server.Time.Day

        # --- Volume ---
        self.min_volume = self.symbol.VolumeInUnitsMin

        # --- Trend bias state ---
        self.trend_bias            = "NEUTRAL"
        self._bias_violation_count = 0
        self._bias_candle_count    = 0
        self.bbw_invalidated       = False

        # --- Indicator thresholds ---
        self.adx_min  = 45
        self.adx_max  = 80

        self.vol_pct_min = 5

        self.hurst_min  = 0.30
        self.hurst_max  = 0.78
        self.hurst_good = 0.70

        self.hacc_decel       = -0.05
        self.hacc_min         = 0.10
        self.hacc_high        = 0.80
        self.hacc_anomalous   = 2.5

        self._h_buffer   = []
        self._ha_buffer  = []
        self._adx_buffer = []

        # --- Loss-zone memory ---
        self.last_loss_price_zone = None
        self.loss_zone_timestamp  = None
        self.ZONE_TOLERANCE_PIPS  = 20
        self.ZONE_EXPIRY_BARS     = 20

        api.Print("BotTradingM5 started")

    # ======================================================
    # SAFETY HELPERS
    # ======================================================
    def safe_value(self, val, default=0.0):
        """Return val if it is a valid number; otherwise return default."""
        if val is None:
            return default
        if isinstance(val, float) and math.isnan(val):
            return default
        return val

    def _is_in_loss_zone(self, current_price):
        """Return True if current_price is within ZONE_TOLERANCE_PIPS of the last stop-loss price."""
        if self.last_loss_price_zone is None:
            return False
        distance_pips = abs(current_price - self.last_loss_price_zone) / self.symbol.PipSize
        return distance_pips < self.ZONE_TOLERANCE_PIPS

    # ======================================================
    # ON BAR  —  STRATEGY ENGINE
    # ======================================================
    def on_bar(self):
        try:
            # --- Pause management ---
            if self.pause_bars_remaining > 0:
                self.pause_bars_remaining -= 1
                if self.pause_bars_remaining > 0:
                    api.Print(f"PAUSE: {self.pause_bars_remaining} bars remaining")
                    api.Chart.DrawStaticText(
                        "PAUSE_STATUS",
                        f"PAUSE: {self.pause_bars_remaining}/2 bars",
                        VerticalAlignment.Top,
                        HorizontalAlignment.Left,
                        Color.Yellow)
                    return
                else:
                    api.Print("PAUSE ENDED")
                    api.Chart.RemoveObject("PAUSE_STATUS")

            # --- Loss-zone expiry ---
            if self.loss_zone_timestamp is not None:
                bars_since_loss = (api.Server.Time - self.loss_zone_timestamp).TotalMinutes / 5
                if bars_since_loss > self.ZONE_EXPIRY_BARS:
                    self.last_loss_price_zone = None
                    self.loss_zone_timestamp  = None

            if self.has_position() or self.has_pending_order():
                return

            # --- Reset signals from previous bar ---
            self.signal_mode  = None
            self.signal_price = 0.0

            current_bid = self.symbol.Bid
            current_ask = self.symbol.Ask

            # --- Minimum bar count guard ---
            bars = api.Bars
            if bars.Count < 60:
                return

            # --- Extract last 60 M5 bars (done once per bar) ---
            count     = bars.Count
            start_idx = count - 60

            close = [bars.ClosePrices[i] for i in range(start_idx, count)]
            open_ = [bars.OpenPrices[i]  for i in range(start_idx, count)]
            high  = [bars.HighPrices[i]  for i in range(start_idx, count)]
            low   = [bars.LowPrices[i]   for i in range(start_idx, count)]

            # --- Compute indicators ---
            atr          = self.calc_atr(high, low, close, 10)
            ema_fast_5m  = self.ema(close, self.periodo_fast)
            ema_slow_5m  = self.ema(close, self.periodo_slow)
            ema_fast     = self.ema(close, 6)   # trigger EMA

            if ema_slow_5m[-1] is None or atr[-1] is None:
                return

            self.check_entry(
                current_bid, current_ask, self.prices_15s,
                open_, high, low, close,
                atr, ema_fast_5m, ema_slow_5m, ema_fast)

        except Exception as e:
            api.Print(f"ERR ON_BAR: {e}")
            api.Print(traceback.format_exc())

    # ======================================================
    # ON TICK  —  REAL-TIME PROTECTION
    # ======================================================
    def on_tick(self):
        try:
            now         = api.Server.Time
            current_bid = self.symbol.Bid
            current_ask = self.symbol.Ask

            # --- Price buffer sampling (dynamic interval) ---
            interval = (self.PRICE_SAMPLE_BOOTSTRAP
                        if len(self.prices_15s) < self.MIN_PRICES
                        else self.PRICE_SAMPLE_NORMAL)

            if (now - self.last_sample_ts).TotalSeconds >= interval:
                self.prices_15s.append(current_bid)
                self.last_sample_ts = now

                # Buffer cleanup
                if len(self.prices_15s) >= 2000:
                    self.prices_15s = self.prices_15s[-1500:]

                # Warm-up completion check
                if not self.ready and len(self.prices_15s) >= self.MIN_PRICES:
                    self.ready = True
                    api.Print("BUFFER FULL — READY")

            if not self.ready or api.Bars.Count < 60:
                return

            # --- Build lightweight indicator slice ---
            pos   = self.get_position()
            bars  = api.Bars
            count = bars.Count
            start_idx = count - 45

            close_lite = [bars.ClosePrices[i] for i in range(start_idx, count)]
            open_lite  = [bars.OpenPrices[i]  for i in range(start_idx, count)]
            high_lite  = [bars.HighPrices[i]  for i in range(start_idx, count)]
            low_lite   = [bars.LowPrices[i]   for i in range(start_idx, count)]

            atr_lite        = self.calc_atr(high_lite, low_lite, close_lite, 10)
            ema_fast_5m_lite = self.ema(close_lite, self.periodo_fast)
            ema_slow_5m_lite = self.ema(close_lite, self.periodo_slow)
            ema_fast_lite    = self.ema(close_lite, 6)

            if ema_slow_5m_lite[-1] is None or atr_lite[-1] is None:
                return

            self.manage_bias(close_lite, open_lite, ema_fast_5m_lite, ema_slow_5m_lite, atr_lite)

            # --- Position management ---
            if pos:
                self.manage_position(
                    pos, open_lite, close_lite,
                    atr_lite, ema_fast_lite, ema_fast_5m_lite,
                    self.prices_15s)

        except Exception as e:
            api.Print(f"ERR ON_TICK: {e}")
            api.Print(traceback.format_exc())

    # ======================================================
    # ENTRY LOGIC
    # ======================================================
    def check_entry(self, current_bid, current_ask, prices,
                    open_, high, low, close,
                    atr, ema_fast_5m, ema_slow_5m, ema_fast):
        now = api.Server.Time

        # --- Daily reset ---
        if now.Day != self.last_stop_reset_day:
            self.last_stop_reset_day  = now.Day
            self.trend_bias           = "NEUTRAL"
            self.last_loss_price_zone = None
            self.loss_zone_timestamp  = None

        if not self.trading_setup_allowed():
            self.trend_bias = "NEUTRAL"
            return False

        # --- Daily circuit breaker ---
        if self.check_daily_stop_limit(1):
            api.Chart.DrawStaticText(
                "STOP_STATUS", "MAX DAILY STOPS REACHED (1/1)",
                VerticalAlignment.Top, HorizontalAlignment.Right, Color.Red)
            return
        else:
            api.Chart.RemoveObject("STOP_STATUS")

        # --- Monthly money management ---
        monthly_status  = self.get_monthly_status(profit_target_pct=5.0, soft_dd_pct=2.0, hard_dd_pct=4.0)
        risk_multiplier = 1.0

        if monthly_status == 1:
            api.Chart.DrawStaticText(
                "MM_STATUS", "PROFIT LOCK: Month closed in profit",
                VerticalAlignment.Top, HorizontalAlignment.Center, Color.Lime)
            return
        elif monthly_status == 2:
            api.Chart.DrawStaticText(
                "MM_STATUS", "HARD STOP: Max monthly loss (-4%) reached",
                VerticalAlignment.Top, HorizontalAlignment.Center, Color.Red)
            return
        elif monthly_status == 0.5:
            api.Chart.DrawStaticText(
                "MM_STATUS", "RECOVERY MODE: Risk halved (-2% drawdown)",
                VerticalAlignment.Top, HorizontalAlignment.Center, Color.Orange)
            risk_multiplier = 0.5
        else:
            api.Chart.RemoveObject("MM_STATUS")
            risk_multiplier = 1.0

        # --- Anti-spam guards ---
        if self.last_entry_time is not None:
            if (now - self.last_entry_time).TotalSeconds < 10:
                return

        if self.has_pending_order():
            return

        if self.order_lock and not self.has_position():
            api.Print("Order lock released")
            self.order_lock = False

        if self.order_lock:
            return

        # --- Indicator validity check ---
        if any(x is None for x in (ema_fast[-1], ema_fast_5m[-1], ema_slow_5m[-1], atr[-1])):
            return

        # --- Bias detection ---
        if self.trend_bias == "NEUTRAL":
            self.check_setup(close, high, low, ema_fast_5m, ema_slow_5m, atr)

        # --- Bias display ---
        status_color = Color.Gray
        if self.trend_bias == "LONG":  status_color = Color.Lime
        elif self.trend_bias == "SHORT": status_color = Color.Red
        api.Chart.DrawStaticText(
            "BIAS_LOCK", f"BIAS: {self.trend_bias}",
            VerticalAlignment.Bottom, HorizontalAlignment.Right, status_color)

        if self.trend_bias == "NEUTRAL":
            return

        # --- LONG entry ---
        if self.trend_bias == "LONG":
            is_valid, entry_price, rr = self.early_long_trigger(
                current_bid, current_ask, prices,
                ema_fast_5m, ema_slow_5m, open_, high, low, close, atr, ema_fast)

            if is_valid:
                execute_market = False
                if current_ask > entry_price:
                    slippage_pips = (current_ask - entry_price) / self.symbol.PipSize
                    execute_market = True
                    api.Print(f"GAP DETECTED: Market order (slippage: {slippage_pips:.1f}p)")

                sl_pips = self.planned_sl_pips if hasattr(self, 'planned_sl_pips') else 20.0
                volume  = self.calc_volume(sl_pips, risk_multiplier)

                if volume < self.symbol.VolumeInUnitsMin:
                    api.Print(f"VOLUME BLOCKED: {volume}")
                    return

                margin = self.symbol.GetEstimatedMargin(TradeType.Buy, volume)
                if margin > self.account.FreeMargin * 0.8:
                    api.Print(f"INSUFFICIENT MARGIN: free={self.account.FreeMargin:.2f}")
                    return

                if execute_market:
                    api.ExecuteMarketOrder(
                        TradeType.Buy, self.symbol, volume, "AdvancedBot",
                        sl_pips, sl_pips * rr)
                else:
                    expiry = api.Server.Time.AddMinutes(20)
                    result = api.PlaceStopOrder(
                        TradeType.Buy, self.symbol, volume, entry_price,
                        "AdvancedBot", sl_pips, sl_pips * rr, expiry)
                    if result.IsSuccessful:
                        api.Print(f"LONG TRAP SET @ {entry_price}")

                self.order_lock      = True
                self.last_entry_time = api.Server.Time

        # --- SHORT entry ---
        elif self.trend_bias == "SHORT":
            is_valid, entry_price, rr = self.early_short_trigger(
                current_bid, current_ask, prices,
                ema_fast_5m, ema_slow_5m, open_, low, high, close, atr, ema_fast)

            if is_valid:
                execute_market = False
                if current_bid < entry_price:
                    slippage_pips = (entry_price - current_bid) / self.symbol.PipSize
                    execute_market = True
                    api.Print(f"GAP DETECTED: Market order (slippage: {slippage_pips:.1f}p)")

                sl_pips = self.planned_sl_pips if hasattr(self, 'planned_sl_pips') else 20.0
                volume  = self.calc_volume(sl_pips, risk_multiplier)

                if volume < self.symbol.VolumeInUnitsMin:
                    api.Print(f"VOLUME BLOCKED: {volume}")
                    return

                margin = self.symbol.GetEstimatedMargin(TradeType.Sell, volume)
                if margin > self.account.FreeMargin * 0.8:
                    api.Print(f"INSUFFICIENT MARGIN: free={self.account.FreeMargin:.2f}")
                    return

                if execute_market:
                    api.ExecuteMarketOrder(
                        TradeType.Sell, self.symbol, volume, "AdvancedBot",
                        sl_pips, sl_pips * rr)
                else:
                    expiry = api.Server.Time.AddMinutes(20)
                    result = api.PlaceStopOrder(
                        TradeType.Sell, self.symbol, volume, entry_price,
                        "AdvancedBot", sl_pips, sl_pips * rr, expiry)
                    if result.IsSuccessful:
                        api.Print(f"SHORT TRAP SET @ {entry_price}")

                self.order_lock      = True
                self.last_entry_time = api.Server.Time

    # ======================================================
    # POSITION MANAGEMENT
    # ======================================================
    def manage_position(self, pos, open_, close, atr, ema_fast, ema_fast_5m, prices):
        if pos is None or pos.VolumeInUnits <= 0:
            return

        now      = api.Server.Time
        duration = (now - pos.EntryTime).TotalSeconds
        entry    = pos.EntryPrice
        sl       = pos.StopLoss

        if sl is None:
            return

        risk = abs(entry - sl)
        if risk <= 0:
            return

        if pos.TradeType == TradeType.Buy:
            price    = self.symbol.Bid
            profit_r = (price - entry) / risk
        else:
            price    = self.symbol.Ask
            profit_r = (entry - price) / risk

        # Track near-TP positions
        if profit_r >= 0.5:
            self.near_tp_reaches.add(pos.Id)

        # --- Early reversal exit ---
        if pos.Id in self.near_tp_reaches:
            if pos.TradeType == TradeType.Buy:
                if self.simple_reversal_long(open_, close, atr, ema_fast, ema_fast_5m):
                    api.ClosePosition(pos)
                    api.Print(f"EARLY EXIT (reversal) | R={profit_r:.2f}")
                    return
            else:
                if self.simple_reversal_short(open_, close, atr, ema_fast, ema_fast_5m):
                    api.ClosePosition(pos)
                    api.Print(f"EARLY EXIT (reversal) | R={profit_r:.2f}")
                    return

        # --- Timeout: close stalling trades ---
        MAX_DURATION_SOFT = 2700   # 45 min
        MAX_DURATION_HARD = 5400   # 90 min

        if duration > MAX_DURATION_SOFT and profit_r < 0.1:
            pos.Close()
            api.Print(f"TIMEOUT STALL | R={profit_r:.2f} | ID={pos.Id}")
            return

        if duration > MAX_DURATION_HARD:
            result = api.ClosePosition(pos)
            if result is None or (hasattr(result, 'IsSuccessful') and not result.IsSuccessful):
                api.Print("TIMEOUT CLOSE FAILED — retrying next tick")
            else:
                api.Print(f"TIMEOUT CLOSE | R={profit_r:.2f}")

    def manage_bias(self, close, open_, ema_fast_5m, ema_slow_5m, atr):
        atr_current       = self.atr_mean(atr, 5)
        ema_gap_threshold = atr_current * 0.4
        _, _, bb_w_pct    = self.get_bollinger_squeeze(close, 20, 2, 20)

        def _count_bbw_violation():
            """Increment or decrement violation count based on BBw percentile."""
            if (bb_w_pct > 90 or bb_w_pct < 20) and not self.bbw_invalidated:
                self.bbw_invalidated = True
                return 1
            elif self.bbw_invalidated and (25 < bb_w_pct < 85):
                self.bbw_invalidated = False
                return -1
            return 0

        def _reset_bias(direction):
            self.trend_bias            = "NEUTRAL"
            self._bias_violation_count = 0
            self._bias_candle_count    = 0
            self.bbw_invalidated       = False
            api.Print(f"BIAS RESET {direction} -> accumulated violations")
            for order in api.PendingOrders:
                trade_type = TradeType.Buy if direction == "LONG" else TradeType.Sell
                if order.Label == "AdvancedBot" and order.TradeType == trade_type:
                    api.CancelPendingOrder(order)

        # --- LONG bias reset logic ---
        if self.trend_bias == "LONG":
            violations = 0

            # A. EMA cross (weighted double)
            if ema_fast_5m[-1] < ema_slow_5m[-1] - ema_gap_threshold:
                violations += 2

            # B. Structural break below slow EMA
            candle_close    = min(close[-1], open_[-1])
            reset_threshold = max(self.symbol.PipSize * 15, atr_current * 0.5)
            if candle_close < ema_slow_5m[-1] - reset_threshold:
                violations += 1

            # C. BBw extreme expansion/contraction
            violations += _count_bbw_violation()

            if violations > 0:
                self._bias_violation_count += violations
            else:
                self._bias_violation_count = max(0, self._bias_violation_count - 1)

            if self._bias_violation_count >= 3:
                _reset_bias("LONG")
            return

        # --- SHORT bias reset logic ---
        elif self.trend_bias == "SHORT":
            violations = 0

            # A. EMA cross (weighted double)
            if ema_fast_5m[-1] > ema_slow_5m[-1] + ema_gap_threshold:
                violations += 2

            # B. Structural break above slow EMA
            candle_close    = max(close[-1], open_[-1])
            reset_threshold = max(self.symbol.PipSize * 15, atr_current * 0.5)
            if candle_close > ema_slow_5m[-1] + reset_threshold:
                violations += 1

            # C. BBw extreme expansion/contraction
            violations += _count_bbw_violation()

            if violations > 0:
                self._bias_violation_count += violations
            else:
                self._bias_violation_count = max(0, self._bias_violation_count - 1)

            if self._bias_violation_count >= 3:
                _reset_bias("SHORT")

    # ======================================================
    # POSITION OPENED CALLBACK
    # ======================================================
    def on_position_opened(self, args):
        position = args.Position
        if position.SymbolName != self.symbol.Name or position.Label != "AdvancedBot":
            return

        self.order_lock      = True
        self.last_entry_time = api.Server.Time

        if not (hasattr(self, 'planned_entry_price') and hasattr(self, 'planned_sl_pips')):
            return

        entry_real    = position.EntryPrice
        entry_planned = self.planned_entry_price
        sl_pips       = self.planned_sl_pips

        # Slippage calculation
        if position.TradeType == TradeType.Buy:
            slippage_pips = (entry_real - entry_planned) / self.symbol.PipSize
        else:
            slippage_pips = (entry_planned - entry_real) / self.symbol.PipSize

        # Cancel trade if slippage exceeds threshold
        if abs(slippage_pips) > 9.5:
            api.ClosePosition(position)
            api.Print(f"TRADE CANCELLED — excessive slippage: {slippage_pips:.1f}p")
            self.pause_bars_remaining = 2
            api.Print("PAUSE ACTIVATED: 2 bars")
            self.order_lock = False
            return

        # Recompute SL/TP from actual fill price
        if position.TradeType == TradeType.Buy:
            new_sl = entry_real - (sl_pips * self.symbol.PipSize)
            new_tp = entry_real + (sl_pips * self.rr * self.symbol.PipSize)
        else:
            new_sl = entry_real + (sl_pips * self.symbol.PipSize)
            new_tp = entry_real - (sl_pips * self.rr * self.symbol.PipSize)

        try:
            res_sl = position.ModifyStopLossPrice(new_sl)
            res_tp = position.ModifyTakeProfitPrice(new_tp)

            sl_failed = res_sl is None or (hasattr(res_sl, 'IsSuccessful') and not res_sl.IsSuccessful)
            tp_failed = res_tp is None or (hasattr(res_tp, 'IsSuccessful') and not res_tp.IsSuccessful)

            if sl_failed or tp_failed:
                api.Print("SL/TP MODIFICATION FAILED — closing position for safety")
                api.ClosePosition(position)
                self.pause_bars_remaining = 3
                self.order_lock = False
                return
        except Exception as e:
            api.Print(f"SL/TP modification error: {e}")

        api.Print(f"TRAP TRIGGERED: order {position.Id} filled | slippage={slippage_pips:.1f}p")

    # ======================================================
    # POSITION CLOSED CALLBACK
    # ======================================================
    def on_position_closed(self, args):
        position = args.Position
        reason   = args.Reason

        if position.SymbolName != self.symbol.Name or position.Label != "AdvancedBot":
            return

        # Unlock engine immediately
        self.order_lock      = False
        self.last_entry_time = None

        # Retrieve closed trade from history
        closed_trade  = None
        history_count = api.History.Count
        for i in range(history_count - 1, -1, -1):
            trade = api.History[i]
            if trade.PositionId == position.Id:
                closed_trade = trade
                break

        if not closed_trade:
            api.Print(f"LOG ERROR: trade {position.Id} not found in history")
            return

        close_price = closed_trade.ClosingPrice
        net_pnl     = closed_trade.NetProfit

        # R-multiple calculation
        r_mult = 0.0
        if position.StopLoss is not None:
            risk = abs(position.EntryPrice - position.StopLoss)
            if risk > 0:
                if position.TradeType == TradeType.Buy:
                    r_mult = (close_price - position.EntryPrice) / risk
                else:
                    r_mult = (position.EntryPrice - close_price) / risk

        outcome = str(reason).upper()
        icon    = "WIN" if net_pnl > 0 else "LOSS"

        api.Print("=== POSITION CLOSED ===")
        api.Print(f"Result : {outcome} [{icon}]")
        api.Print(f"PnL    : {net_pnl:.2f} | R-Multiple: {r_mult:.2f}R")
        api.Print(f"Entry  : {position.EntryPrice:.5f} | Close: {close_price:.5f}")
        api.Print("=======================")

        # Loss handling
        if net_pnl < 0:
            self.last_loss_price_zone = position.EntryPrice
            self.loss_zone_timestamp  = api.Server.Time
            api.Print(f"LOSS ZONE RECORDED: {position.EntryPrice:.5f} ±{self.ZONE_TOLERANCE_PIPS}p")
            if self.pause_bars_remaining == 0:
                self.pause_bars_remaining = 2
                api.Print("PAUSE ACTIVATED: 2 bars after loss")
        else:
            # Winning trade clears the loss zone
            self.last_loss_price_zone = None
            self.loss_zone_timestamp  = None

        # Clean up near-TP set
        if hasattr(self, 'near_tp_reaches'):
            self.near_tp_reaches.discard(position.Id)

        # Circuit breaker status
        if self.check_daily_stop_limit(1):
            api.Print("DAILY STOP LIMIT REACHED — bot paused for today")

