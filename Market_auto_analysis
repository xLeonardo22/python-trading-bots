                return False
        # 1. Candela rossa forte
        body_size = open_[-1] - close[-1]
        avg_body_3 = self.get_avg_body_size(open_, close, 3)
        
        strong_red = body_size > avg_body_3 * 1.5  # Candela 50% più grande
        
        if not strong_red:
            return False  # Se candela non è forte, no exit
        
        # 2. MATEMATICA: Hurst sta decelerando?
        # (Se posizione è aperta, hai già close, calcola hurst)
        if len(close) >= 8:  # Serve periodo 10 + 3
            hurst_now = self.get_fractal_efficiency(close, 10)
            hurst_prev = self.get_fractal_efficiency(close[:-3], 10)
            
            if hurst_prev > 0:
                hurst_acc = (hurst_now - hurst_prev) / hurst_prev
                
                # Se Hurst decelera < -10%, direzione persa
                if hurst_acc < -0.20:
                    api.Print(f"EXIT MATH: Hurst decel {hurst_acc:.2f}")
                    return True
        
        # 3. STRUTTURA: Prezzo chiude sotto EMA fast?
        if close[-1] < ema_fast_5m[-1]:
            # E inoltre rompe minimo precedente
            if close[-1] < min(close[-2], open_[-2]):
                api.Print(f"EXIT STRUCT: Sotto EMA + rottura minimo")
                return True       
        return False

