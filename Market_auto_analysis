    def check_trigger(self, close, atr):
        """
        Check whether a confirmed entry trigger exists in the current direction.
        Returns (can_enter: bool, reason: str).
        """
        bb_b, _, _    = self.get_bollinger_squeeze(close, 20, 2, 20)
        accel         = self.get_quick_acceleration(close)
        hurst         = self.get_fractal_efficiency(close, 10)
        hurst_acc     = self.get_hurst_acceleration(close)
        vol_pct       = self.get_volatility_percentile(atr, 20)

        if self.trend_bias == "LONG":
            if hurst < 0.45:
                return False, ""
            if bb_b > 85 and accel > 0.001:
                return True, "L-ACCEL"
            if bb_b > 80 and hurst_acc < -0.05 and vol_pct > 30:
                return True, "L-DECEL"

        if self.trend_bias == "SHORT":
            if hurst < 0.35:
                return False, ""
            if bb_b < 10 and accel < -0.001:
                return True, "S-ACCEL"

        return False, ""

    def check_setup(self, close, high, low, ema_fast_5m, ema_slow_5m, atr):
        """
        Evaluate whether market conditions warrant setting the trend bias.
        Requires: healthy ADX (25–65), safe EMA separation, and normal BBw regime.
        """
        adx, _, _ = self.calc_adx(high, low, close, 14)
        atr_cur   = self.atr_mean(atr, 5)
        _, _, bb_w_pct = self.get_bollinger_squeeze(close, 20, 2, 20)

        trend_healthy = 25 <= adx <= 65
        regime_ok     = 20 < bb_w_pct <= 80

        # LONG structure
        ema_spread       = ema_fast_5m[-1] - ema_slow_5m[-1]
        long_structure   = ema_fast_5m[-1] > ema_slow_5m[-1] and ema_spread > atr_cur * 0.3

        if long_structure and trend_healthy and regime_ok:
            self.trend_bias = "LONG"
            api.Print("BIAS -> LONG")
            return True

        # SHORT structure
        ema_spread_short = ema_slow_5m[-1] - ema_fast_5m[-1]
        short_structure  = ema_fast_5m[-1] < ema_slow_5m[-1] and ema_spread_short > atr_cur * 0.3

        if short_structure and trend_healthy and regime_ok:
            self.trend_bias = "SHORT"
            api.Print("BIAS -> SHORT")
            return True

        return False

