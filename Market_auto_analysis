            entry = pos.EntryPrice
            sl = pos.StopLoss
            if sl is None: return False
            rischio = abs(entry - sl)
            prezzo = self.symbol.Bid
            profit_R = (prezzo - entry) / rischio
            
            # Non uscire mai prima di 0.7R di profitto
            # Sotto quella soglia, lascia che SL decida
