    def get_monthly_status(self, profit_target_pct=5.0, soft_dd_pct=2.0, hard_dd_pct=4.0):
        """
        Gestisce lo stato del mese con logica RESET su 2 TP consecutivi.
        - Restituisce 0: Rischio Normale (1.0)
        - Restituisce 1: Profit Lock (Target Mensile Raggiunto)
        - Restituisce 2: Hard Stop (Mese Perso > 4%)
        - Restituisce 0.5: Recovery Mode (Rischio Dimezzato > 2%)
        """
        # Accesso sicuro ai dati globali cTrader
        now = api.Server.Time
        current_month = now.Month
        current_year = now.Year    
        # Recupero storico filtrato (Solo mese corrente, solo questo Bot)
        monthly_trades = [
            h for h in api.History 
            if h.Label == "AdvancedBot" 
            and h.ClosingTime.Month == current_month
            and h.ClosingTime.Year == current_year]      
        # Ordiniamo cronologicamente (dal più vecchio al più recente)
        monthly_trades.sort(key=lambda x: x.ClosingTime)       
        # Calcoli di base
        total_pnl = sum(t.NetProfit for t in monthly_trades)
        start_balance = api.Account.Balance - total_pnl      
        if start_balance <= 0: return 0 # Sicurezza contro divisione per zero    
        # Percentuale attuale rispetto all'inizio mese
        # Esempio: Se Balance 10000 e PnL -300 -> current_pct = -3.0
        current_pct = (total_pnl / start_balance) * 100.0       
        # 1. CONTROLLO HARD STOP (-4%)
        # Se siamo sotto il -4%, fine dei giochi. Priorità assoluta.
        if current_pct <= -hard_dd_pct:
            return 2 # STOP TOTALE
        # 2. CONTROLLO PROFIT LOCK (Opzionale: Protezione guadagni)
        # Se vuoi mantenere la logica che blocca se tocchi il +5% e poi perdi
        target_money = start_balance * (profit_target_pct / 100.0)
        hit_target = False
        running_pnl = 0.0
        tolleranza = start_balance * 0.002       
        for t in monthly_trades:
            running_pnl += t.NetProfit
            if running_pnl >= target_money: hit_target = True
            # Se avevamo toccato il target e ora prendiamo uno stop
            if hit_target and t.NetProfit < -tolleranza:
                return 1 # STOP (Profit Lock)
        # 3. CONTROLLO SOFT DRAWDOWN (-2%) con LOGICA RESET
        if current_pct <= -soft_dd_pct:        
            # Siamo sotto il -2%. Di base dovremmo dimezzare il rischio.
            # MA controlliamo se abbiamo fatto 2 TP consecutivi recenti.         
            reset_triggered = False         
            if len(monthly_trades) >= 2:
                last_trade = monthly_trades[-1] # L'ultimo chiuso
                prev_trade = monthly_trades[-2] # Il penultimo chiuso             
                # Se entrambi sono positivi (Take Profit)
                if last_trade.NetProfit > 0 and prev_trade.NetProfit > 0:
                    reset_triggered = True          
            if reset_triggered:
                return 0 # RISCHIO NORMALE (Reset avvenuto!)
            else:
                return 0.5 # RISCHIO DIMEZZATO (Siamo ancora in difficoltà)
        # Se va tutto bene (sopra il -2%)
        return 0 # NORMALE
        
    def get_percentile(self, values, period):
        """Percentile del valore attuale rispetto agli ultimi N periodi"""
        if len(values) < period:
            return 50
        current = values[-1]
        window = [values[-i] for i in range(1, period + 1)]
        rank = sum(1 for v in window if v <= current)
        return int(rank / period * 100)

    # Calcola la media dei corpi (valore assoluto) delle ultime N candele
    def get_avg_body_size(self, open_, close, period):
        """Media dei corpi delle ultime N candele"""
        if len(close) < period + 1: 
            return 0.0       
        total_body = 0.0
        for i in range(1, period + 1):
            total_body += abs(close[-i] - open_[-i])        
        return total_body / period  
         
    def get_volatility_percentile(self, atr, period=20):
        """Dove si trova l'ATR attuale rispetto al range recente?"""
        recent = [a for a in atr[-period:] if a is not None]
        if len(recent) < period: return 50       
        current = recent[-1]
        rank = sum(1 for v in recent if v <= current)
        return (rank / period) * 100

    def get_fractal_efficiency(self, close, period=10): #Quanto è efficiente il movimento? Va dritto o zigzaga?
        change = abs(close[-1] - close[-period]) # Spostamento netto
        path_length = 0.0       
        for i in range(1, period + 1):
            path_length += abs(close[-i] - close[-i-1]) # Somma di tutti i passettini             
        if path_length == 0: return 0.0        
        return change / path_length

    def get_hurst_acceleration(self, close, period=10):
        """Sta aumentando la direzionalità? (Impulso nascente)"""
        if len(close) < period + 3:
            return 0.0        
        hurst_now = self.get_fractal_efficiency(close, period)
        hurst_prev = self.get_fractal_efficiency(close[:-3], period)       
        if hurst_prev == 0: 
            return 0.0    
        # Differenza assoluta: range stabile -0.20 / +0.20    
        return hurst_now - hurst_prev

    def get_bollinger_squeeze(self, close, period=20, std_dev=2, pct_lookback=20):
        """Combina posizione + compressione Bollinger + percentile BBw"""
        sma = sum(close[-period:]) / period
        variance = sum([(c - sma)**2 for c in close[-period:]]) / period
        std = math.sqrt(variance)        
        upper = sma + (std * std_dev)
        lower = sma - (std * std_dev)       
        # %B: Dove siamo nel canale? (0-100)
        price = close[-1]
        percent_b = ((price - lower) / (upper - lower)) * 100 if upper != lower else 50        
        # Bandwidth: Quanto è stretto il canale?
        bandwidth = ((upper - lower) / sma) * 100        
        
        # BBw Percentile: rolling su ultime pct_lookback candele
        bbw_pct = 50  # default
        if len(close) >= period + pct_lookback:
            bw_history = []
            for i in range(pct_lookback):
                offset = pct_lookback - 1 - i
                chunk = close[-(period + offset):len(close) - offset] if offset > 0 else close[-period:]
                s = sum(chunk) / period
                v = sum([(c - s)**2 for c in chunk]) / period
                st = math.sqrt(v)
                u = s + (st * std_dev)
                l = s - (st * std_dev)
                bw_history.append(((u - l) / s) * 100 if s != 0 else 0)
            
            count = sum(1 for bw in bw_history if bw <= bandwidth)
            bbw_pct = (count / pct_lookback) * 100
        
        return percent_b, bandwidth, bbw_pct

    def get_quick_acceleration(self, close):
        """
        🆕 VELOCE: Accelerazione su 3 bar (15 min) invece di 10 bar (50 min)
        
        Confronta:
        - Momentum ADESSO (ultimi 3 bar: -1 a -3)
        - Momentum PRIMA (3 bar precedenti: -4 a -6)
        
        Output: numero (tipicamente -0.01 a +0.01)
        - Positivo = sta accelerando
        - Negativo = sta decelerando
        """
        if len(close) < 7:
            return 0.0
        
        # Momentum recente (ultimi 3 bar)
        momentum_now = (close[-1] - close[-3]) / close[-3]
        
        # Momentum precedente (3 bar prima)
        momentum_prev = (close[-4] - close[-6]) / close[-6]
        
        # Accelerazione = differenza
        acceleration = momentum_now - momentum_prev
        
        return acceleration

    def calc_ADX(self, high, low, close, period=14):
        """ADX con smoothing Wilder corretto. Restituisce (adx, plus_di, minus_di)."""
        if len(close) < period * 2 + 1:
            return 0.0, 0.0, 0.0

        tr_list, plus_dm_list, minus_dm_list = [], [], []

        for i in range(1, len(close)):
            tr = max(
                high[i] - low[i],
                abs(high[i] - close[i - 1]),
                abs(low[i] - close[i - 1])
            )
            tr_list.append(tr)

            up_move   = high[i] - high[i - 1]
            down_move = low[i - 1] - low[i]

            if up_move > down_move and up_move > 0:
                plus_dm_list.append(up_move)
            else:
                plus_dm_list.append(0.0)

            if down_move > up_move and down_move > 0:
                minus_dm_list.append(down_move)
            else:
                minus_dm_list.append(0.0)

        if len(tr_list) < period:
            return 0.0, 0.0, 0.0

        atr_w      = sum(tr_list[:period])
        plus_dm_w  = sum(plus_dm_list[:period])
        minus_dm_w = sum(minus_dm_list[:period])

        dx_list = []
        plus_di, minus_di = 0.0, 0.0

        for i in range(period, len(tr_list)):
            atr_w      = atr_w      - (atr_w / period)      + tr_list[i]
            plus_dm_w  = plus_dm_w  - (plus_dm_w / period)  + plus_dm_list[i]
            minus_dm_w = minus_dm_w - (minus_dm_w / period) + minus_dm_list[i]

            if atr_w == 0:
                continue

            plus_di  = (plus_dm_w / atr_w) * 100
            minus_di = (minus_dm_w / atr_w) * 100

            di_sum = plus_di + minus_di
            dx_list.append(0.0 if di_sum == 0 else abs(plus_di - minus_di) / di_sum * 100)

        if len(dx_list) < period:
            return 0.0, plus_di, minus_di

        adx = sum(dx_list[:period]) / period
        for dx_val in dx_list[period:]:
            adx = (adx * (period - 1) + dx_val) / period

        return adx, plus_di, minus_di

    #======================================
    def check_trigger(self, close, atr):
        bb_b, bb_w, bb_w_pct   = self.get_bollinger_squeeze(close, 20, 2, 20)
        accel = self.get_quick_acceleration(close)
        hurst = self.get_fractal_efficiency(close, 10)
        hurst_acc = self.get_hurst_acceleration(close)
        vol_pct = self.get_volatility_percentile(atr, 20)

        # Filtro Efficienza: Il grafico deve essere "pulito"       
        if self.trend_bias == "LONG":
            if hurst < 0.45: return False, ""

            # Prezzo spinge in alto e accelera
            if bb_b > 85 and accel > 0.001:
                return True, "L-ACCEL"

            if bb_b > 80 and hurst_acc < -0.05 and vol_pct > 30:
                return True, "L-DECEL"
                
        if self.trend_bias == "SHORT":
            if hurst < 0.35: return False, ""

            # Prezzo spinge in basso e accelera
            if bb_b < 10 and accel < -0.001:
                return True, "S-ACCEL"            
        return False, ""
    #======================================
    def check_setup(self, close, high, low, ema_fast_5m, ema_slow_5m, atr):
        # 1. Direzione Medie ed ADX
        adx, _, _ = self.calc_ADX(high, low, close, 14)
        atr_cur = self.atr_mean(atr, 5)
        
        # Filtro ADX: Trend presente ma non esausto
        trend_healthy = 25 <= adx <= 65
        
        # Filtro Volatilità: Evitiamo i picchi folli (esaurimento)
        bb_b, bb_w, bb_w_pct   = self.get_bollinger_squeeze(close, 20, 2, 20)
        regime_ok = 20 < bb_w_pct <= 80 

        structure_long_ok = ema_fast_5m[-1] > ema_slow_5m[-1]
        safe_dist_long = (ema_fast_5m[-1] - ema_slow_5m[-1]) > (atr_cur * 0.3)

        if structure_long_ok and safe_dist_long and trend_healthy and regime_ok:
            self.trend_bias = "LONG"
            api.Print("BIAS -> LONG")
            return True
            
        else:
            structure_short_ok = ema_fast_5m[-1] < ema_slow_5m[-1]
            safe_dist_short = (ema_slow_5m[-1] - ema_fast_5m[-1]) > (atr_cur * 0.3)

            if structure_short_ok and safe_dist_short and trend_healthy and regime_ok:
                self.trend_bias = "SHORT"
                api.Print("BIAS -> SHORT")
                return True
            
        return False
    # ===== FUNZIONI ENTRY FINALE ===== 
    # ======================================================
    # ENTRY TRIGGER — LONG 
    # ======================================================
    def early_long_trigger(self, current_bid, current_ask, prices,
                            ema_fast_5m, ema_slow_5m, open_, high, low,
                            close, atr, ema_fast):

        # ── GUARDIE RAPIDE ──────────────────────────────────────────
        if not self.trading_time_allowed():
            return False, 0.0, 1.8
        if self._is_in_loss_zone(current_ask):
            return False, 0.0, 1.8

        # ── CALCOLO INDICATORI ──────────────────────────────────────
        vol_pct   = self.get_volatility_percentile(atr, 20)
        bb_b, bb_w, bb_w_pct   = self.get_bollinger_squeeze(close, 20, 2, 20)
        hurst     = self.get_fractal_efficiency(close, 10)
        hurst_acc = self.get_hurst_acceleration(close)
        atr_cur   = self.atr_mean(atr, 5)
        adx, _, _ = self.calc_ADX(high, low, close, 7)

        # ── TRIGGER REALE ───────────────
        puo_entrare, motivo = self.check_trigger(close, atr)
        if not puo_entrare:
            return False, 0.0, 1.8

        # ── CALCOLO ENTRY E SL ──────────────────────────────────────
        local_high   = api.Bars.HighPrices.Last(1)
        atr_buffer   = atr_cur * 0.085
        entry_price  = local_high + atr_buffer

        sl_structural    = max(low[-2], ema_slow_5m[-2])
        sl_distance_pips = (entry_price - sl_structural) / self.symbol.PipSize

        if sl_distance_pips <= 0:
            return False, 0.0, 1.8
        if not (self.sl_min <= sl_distance_pips <= self.MAX_SL_PIPS):
            return False, 0.0, 1.8

        # Gap entry: se devo salire più di 10 pips per entrare
        # in 20 minuti è improbabile che scatti
        gap_pips = (entry_price - current_ask) / self.symbol.PipSize
        if gap_pips > 10:
            return False, 0.0, 1.8

        # ── RR ADATTIVO basato su forza del trend ───────────────────
        if  hurst > 0.6:
            rr = 2.0
        else:
            rr = 1.7

        self.planned_sl_pips     = sl_distance_pips
        self.planned_entry_price = entry_price
        self.rr = rr

        api.Print(f"📊 BBw:{bb_w:.2f}, BBb:{bb_b:.2f} V:{vol_pct:.0f} H:{hurst:.2f} Ha:{hurst_acc:.3f} ADX:{adx:.0f} Dir:LONG | {motivo}, rr:{rr}")

        return True, entry_price, rr

