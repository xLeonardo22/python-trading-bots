    def safe_value(self, val, default=0.0): 
        """Restituisce un valore sicuro (mai NaN o None).""" 
        if val is None: 
            return default 
        if isinstance(val, float) and math.isnan(val): 
            return default 
        return val

    def _is_in_loss_zone(self, current_price):
        """Evita di rientrare nella fascia di prezzo dove si è perso di recente."""
        if self.last_loss_price_zone is None:
            return False
        distance_pips = abs(current_price - self.last_loss_price_zone) / self.symbol.PipSize
        return distance_pips < self.ZONE_TOLERANCE_PIPS
    # ======================================================
    # ON BAR (IL CERVELLO - CALCOLI PESANTI)
    # ======================================================
    def on_bar(self):
        try:
            # ===== 🆕 GESTIONE PAUSA (PRIMA DI TUTTO!) =====
            if self.pause_bars_remaining > 0:
                self.pause_bars_remaining -= 1                
                if self.pause_bars_remaining > 0:
                    # Ancora in pausa
                    api.Print(f"⏸️ PAUSA: {self.pause_bars_remaining} candele rimaste")
                    api.Chart.DrawStaticText("PAUSE_STATUS", 
                        f"⏸️ PAUSA: {self.pause_bars_remaining}/2 candele", 
                        VerticalAlignment.Top, 
                        HorizontalAlignment.Left, 
                        Color.Yellow)
                    return  # SKIP tutto il resto!
                else:
                    # Pausa terminata
                    api.Print("✅ PAUSA TERMINATA - Bot riattivato")
                    api.Chart.RemoveObject("PAUSE_STATUS")
            # ===== SCADENZA LOSS ZONE =====
            if self.loss_zone_timestamp is not None:
                bars_since_loss = (api.Server.Time - self.loss_zone_timestamp).TotalMinutes / 5
                if bars_since_loss > self.ZONE_EXPIRY_BARS:
                    self.last_loss_price_zone = None
                    self.loss_zone_timestamp = None
                    
            if self.has_position() or self.has_pending_order():
                return
            # 1. Reset Segnali della barra precedente
            self.signal_mode = None
            self.signal_price = 0.0  
            current_bid = self.symbol.Bid
            current_ask = self.symbol.Ask
            # 2. Controllo Dati Minimi
            bars = api.Bars
            if bars.Count < 60: return
            # 3. Estrazione Dati (Solo una volta per barra!)
            prices = self.prices_15s  
            # Nota: In on_bar, l'indice -1 è la barra appena chiusa (quella che ci interessa)
            count = bars.Count
            start_idx = count - 60
            
            close = [bars.ClosePrices[i] for i in range(start_idx, count)]
            open_ = [bars.OpenPrices[i] for i in range(start_idx, count)]
            high = [bars.HighPrices[i] for i in range(start_idx, count)]
            low = [bars.LowPrices[i] for i in range(start_idx, count)]
            # 4. Calcolo Indicatori
            atr = self.calcolo_atr(high, low, close, 10)
            ema_fast_5m = self.ema(close, self.periodo_fast) # 20
            ema_slow_5m = self.ema(close, self.periodo_slow) # 40          
            ema_fast = self.ema(close, 6) # Trigger EMA
            if ema_slow_5m[-1] is None or atr[-1] is None: return
            # 5. AGGIORNAMENTO BIAS & CHECK ENTRY
            self.check_entry(current_bid, current_ask, prices, open_, high, low, close, atr, ema_fast_5m, ema_slow_5m, ema_fast)
        except Exception as e:
            api.Print(f"ERR ON_BAR: {e}")
            api.Print(traceback.format_exc())
    # ======================================================
    # TICK (MOTORE CENTRALIZZATO)
    # ======================================================
    def on_tick(self):
        try:
            now = api.Server.Time     
            current_bid = self.symbol.Bid
            current_ask = self.symbol.Ask     
            # 1. GESTIONE BUFFER 15s (Campionamento)
            # Calcoliamo l'intervallo dinamico
            interval = self.PRICE_SAMPLE_BOOTSTRAP if len(self.prices_15s) < self.MIN_PRICES else self.PRICE_SAMPLE_NORMAL            
            if (now - self.last_sample_ts).TotalSeconds >= interval:
                self.prices_15s.append(current_bid)
                self.last_sample_ts = now               
                # PULIZIA BUFFER (La facciamo solo qui, quando serve!)
                if len(self.prices_15s) >= 2000:
                    self.prices_15s = self.prices_15s[-1500:]              
                # Sblocco iniziale
                if not self.ready and len(self.prices_15s) >= self.MIN_PRICES:
                    self.ready = True
                    api.Print("✅ BUFFER PIENO - READY")
            # Se non siamo pronti o cTrader non ha caricato le barre, stop.
            if not self.ready or api.Bars.Count < 60: return
            # ==========================================================
            # 2. CALCOLO DATI & INDICATORI (Se siamo in un operazione)
            # ==========================================================            
            # A. Scarichiamo solo gli ultimi 60 dati M5 (Slice Veloce)
            pos = self.get_position()  
            bars = api.Bars                    
            prices= self.prices_15s
            count = bars.Count
            start_idx = count - 45
            
            close_lite = [bars.ClosePrices[i] for i in range(start_idx, count)]
            open_lite = [bars.OpenPrices[i] for i in range(start_idx, count)]
            high_lite = [bars.HighPrices[i] for i in range(start_idx, count)]
            low_lite = [bars.LowPrices[i] for i in range(start_idx, count)]     
            # Indicatori Veloci
            atr_lite = self.calcolo_atr(high_lite, low_lite, close_lite, 10)
            ema_fast_5m_lite = self.ema(close_lite, self.periodo_fast) # 20
            ema_slow_5m_lite = self.ema(close_lite, self.periodo_slow) # 40
            ema_fast_lite = self.ema(close_lite, 6)  
            if ema_slow_5m_lite[-1] is None or atr_lite[-1] is None: return
            self.manage_bias(close_lite, open_lite, ema_fast_5m_lite, ema_slow_5m_lite, atr_lite)      
                # Controllo Uscita
            if pos:
                self.manage_position(pos, open_lite, close_lite, atr_lite, ema_fast_lite, ema_fast_5m_lite, prices)
        except Exception as e:
            api.Print(f"ERR ON_TICK: {e}")
            api.Print(traceback.format_exc())     
    # ======================================================
    # ENTRY LOGIC 
    # ======================================================
    def check_entry(self, current_bid, current_ask, prices, open_, high, low, close, atr, ema_fast_5m, ema_slow_5m, ema_fast):
        now = api.Server.Time
        current_bar = api.Bars.OpenTimes[-1]
        # --- RESET STOP GIORNALIERI ---
        if now.Day != self.last_stop_reset_day:
            self.last_stop_reset_day = now.Day
            self.trend_bias = "NEUTRAL"
            self.last_loss_price_zone = None
            self.loss_zone_timestamp = None
            #api.Print("Nuovo giorno: contatore stop resettato.")
        if not self.trading_setup_allowed():
            self.trend_bias = "NEUTRAL"
            return False
        # --- CONTROLLO CIRCUIT BREAKER ---
        if self.check_daily_stop_limit(1):
            api.Chart.DrawStaticText("STOP_STATUS", "MAX DAILY STOPS REACHED (3/3)", VerticalAlignment.Top, HorizontalAlignment.Right, Color.Red)
            return
        else:
            api.Chart.RemoveObject("STOP_STATUS")
        # ===== GESTIONE MONEY MANAGEMENT MENSILE ====
        monthly_status = self.get_monthly_status(profit_target_pct=5.0, soft_dd_pct=2.0, hard_dd_pct=4.0)        
        risk_multiplier = 1.0 # Default normale       
        if monthly_status == 1:
            api.Chart.DrawStaticText("MM_STATUS", "🔒 PROFIT LOCK: Mese Chiuso in Verde", VerticalAlignment.Top, HorizontalAlignment.Center, Color.Lime)
            return
        elif monthly_status == 2:
            api.Chart.DrawStaticText("MM_STATUS", "⛔ HARD STOP: Max Loss (-4%) Raggiunto", VerticalAlignment.Top, HorizontalAlignment.Center, Color.Red)
            return
        elif monthly_status == 0.5:
            api.Chart.DrawStaticText("MM_STATUS", "⚠️ RECOVERY MODE: Rischio Dimezzato (-2%)", VerticalAlignment.Top, HorizontalAlignment.Center, Color.Orange)
            risk_multiplier = 0.5 # DIMEZZA IL RISCHIO
        else:
            # Se siamo qui, o va tutto bene, O il rischio è stato resettato dai 2 TP
            api.Chart.RemoveObject("MM_STATUS")
            risk_multiplier = 1.0           
        # --- CONTROLLI PER FAR FUNZIONARE BOT ---       
        if self.last_entry_time is not None:
            if (now - self.last_entry_time).TotalSeconds < 10:
                return   
        if self.has_pending_order(): return   
        if self.order_lock and not self.has_position():
            api.Print(f"Order lock rilasciato")
            self.order_lock = False
        if self.order_lock:
            return
        #======PRIMI CONTROLLI=====
        if any(x is None for x in (ema_fast[-1], ema_fast_5m[-1], ema_slow_5m[-1], atr[-1])):
            return
        # ==========================================================
        # 1. AGGIORNAMENTO STATO (LOCK)
        # ==========================================================
        if self.trend_bias == "NEUTRAL":
            self.check_setup(close, high, low, ema_fast_5m, ema_slow_5m, atr)
        # Visualizzazione stato
        status_color = Color.Gray
        if self.trend_bias == "LONG": status_color = Color.Lime
        elif self.trend_bias == "SHORT": status_color = Color.Red
        api.Chart.DrawStaticText("BIAS_LOCK", f"BIAS: {self.trend_bias}", VerticalAlignment.Bottom, HorizontalAlignment.Right, status_color)
        if self.trend_bias == "NEUTRAL": return
        # ===== ENTRY ===== 
        if self.trend_bias == "LONG":  
            is_valid, entry_price, rr = self.early_long_trigger(current_bid, current_ask, prices, ema_fast_5m, ema_slow_5m, open_, high, low, close, atr, ema_fast)              
            if is_valid:
                execute_market = False
                if current_ask > entry_price:
                    slippage_pips = (current_ask - entry_price) / self.symbol.PipSize
                    execute_market = True
                    api.Print(f"🚀 GAP DETECTED: Market Order (slippage: {slippage_pips:.1f}p)")
                #-- Calcoliamo parametri                              
                stop_loss_pips = self.planned_sl_pips if hasattr(self, 'planned_sl_pips') else 20.0
                volume = self.calc_volume(stop_loss_pips, risk_multiplier)
                if volume < self.symbol.VolumeInUnitsMin:
                    api.Print(f"VOLUME BLOCCATO: {volume}")
                    return
                margin = self.symbol.GetEstimatedMargin(TradeType.Buy, volume)
                if margin > self.account.FreeMargin * 0.8:
                    api.Print(f"FreeMargin={self.account.FreeMargin:.2f}")
                    return
                if execute_market:
                    # ENTRATA MARKET (Il treno è già partito, saltiamo su)
                    api.ExecuteMarketOrder(TradeType.Buy, self.symbol, volume, "AdvancedBot", stop_loss_pips, stop_loss_pips * rr)
                    self.order_lock = True
                    self.last_entry_time = api.Server.Time
                else:
                    # ENTRATA STOP (Il treno è in stazione, piazziamo la trappola)
                    expiry = api.Server.Time.AddMinutes(20)
                    result = api.PlaceStopOrder(
                                TradeType.Buy,
                                self.symbol,
                                volume,
                                entry_price,
                                "AdvancedBot",
                                stop_loss_pips,
                                stop_loss_pips * rr,
                                expiry)
                    self.order_lock = True
                    self.last_entry_time = api.Server.Time
                    if result.IsSuccessful:
                        api.Print(f"⏳ TRAPPOLA LONG PIAZZATA @ {entry_price}")                       
            # ===== ENTRY SHORT =====
        elif self.trend_bias == "SHORT":
            is_valid, entry_price, rr = self.early_short_trigger(current_bid, current_ask, prices, ema_fast_5m, ema_slow_5m, open_, low, high, close, atr, ema_fast)
            if is_valid:
                # --- FIX CRITICO ---
                execute_market = False
                if current_bid < entry_price:
                    slippage_pips = (entry_price - current_bid) / self.symbol.PipSize
                    execute_market = True
                    api.Print(f"🔻 GAP DETECTED: Market Order (slippage: {slippage_pips:.1f}p)")
                #-- Calcoliamo parametri
                stop_loss_pips = self.planned_sl_pips if hasattr(self, 'planned_sl_pips') else 20.0
                volume = self.calc_volume(stop_loss_pips, risk_multiplier)
                if volume < self.symbol.VolumeInUnitsMin:
                    api.Print(f"VOLUME BLOCCATO: {volume}")
                    return                
                margin = self.symbol.GetEstimatedMargin(TradeType.Sell, volume)
                if margin > self.account.FreeMargin * 0.8:
                    api.Print(f"FreeMargin={self.account.FreeMargin:.2f}")
                    return
                if execute_market:
                    api.ExecuteMarketOrder(TradeType.Sell, self.symbol, volume, "AdvancedBot", stop_loss_pips, stop_loss_pips * rr)
                    self.order_lock = True
                    self.last_entry_time = api.Server.Time
                else:
                    expiry = api.Server.Time.AddMinutes(20)
                    result = api.PlaceStopOrder(
                            TradeType.Sell,
                            self.symbol,
                            volume,
                            entry_price,
                            "AdvancedBot",
                            stop_loss_pips,
                            stop_loss_pips * rr,
                            expiry)
                    self.order_lock = True
                    self.last_entry_time = api.Server.Time
                    if result.IsSuccessful:
                        api.Print(f"⏳ TRAPPOLA SHORT PIAZZATA @ {entry_price}")
# ======================================================
# GESTIONE POSIZIONE
# ======================================================
    def manage_position(self, pos, open_, close, atr, ema_fast, ema_fast_5m, prices):
        if pos is None or pos.VolumeInUnits <= 0:
            return
        now = api.Server.Time
        durata = (now - pos.EntryTime).TotalSeconds
        entry = pos.EntryPrice
        sl = pos.StopLoss      
        # Controllo sicurezza calcoli
        if sl is None: return 
        rischio = abs(entry - sl)
        if rischio <= 0: return
        # Prezzo corrente
        if pos.TradeType == TradeType.Buy:
            prezzo = self.symbol.Bid
            profit_R = (prezzo - entry) / rischio
            pips_gain = (prezzo - entry) / self.symbol.PipSize
        else:
            prezzo = self.symbol.Ask
            profit_R = (entry - prezzo) / rischio
            pips_gain = (entry - prezzo) / self.symbol.PipSize
        # ======================================================
        # 2. LOGICHE ESISTENTI (Early Exit & Timeout)
        # ======================================================      
        if profit_R >= 0.5:
            self.near_tp_reaches.add(pos.Id)
        # ===============================
        # INVERSIONE CHIARA
        # ===============================
        if pos.Id in self.near_tp_reaches:
            if pos.TradeType == TradeType.Buy:
                if self.simple_reversal_long(open_, close, atr, ema_fast, ema_fast_5m):
                    api.ClosePosition(pos)
                    api.Print(f"EARLY EXIT SIMPLE | R={profit_R:.2f}")
                    return
            else:
                if self.simple_reversal_short(open_, close, atr, ema_fast, ema_fast_5m):
                    api.ClosePosition(pos)
                    api.Print(f"EARLY EXIT SIMPLE | R={profit_R:.2f}")
                    return
        # ===============================
        # TIMEOUT
        # ===============================
        MAX_DURATION = 2700 # 1h
        if durata > MAX_DURATION:
            if profit_R < 0.1:
                pos.Close()
                api.Print(f"TIMEOUT STALL | R={profit_R:.2f} | ID={pos.Id}")
                return
        if durata > 5400:
            result = api.ClosePosition(pos)
            if result is None or (hasattr(result, 'IsSuccessful') and not result.IsSuccessful):
                api.Print(f"⚠️ TIMEOUT CLOSE FALLITO — riprovo al prossimo tick")
            else:
                api.Print(f"TIMEOUT CLOSE | R={profit_R:.2f}")
            return
    def manage_bias(self, close, open_, ema_fast_5m, ema_slow_5m, atr):       
        atr_current = self.atr_mean(atr, 5)
        ema_gap_threshold = atr_current * 0.4
        bb_b, bb_w, bb_w_pct = self.get_bollinger_squeeze(close, 20, 2, 20)
        
        # ==== LOGICA RESET LONG ====
        if self.trend_bias == "LONG":
            violations = 0
            
            # A. EMA cross
            if ema_fast_5m[-1] < ema_slow_5m[-1] - ema_gap_threshold:
                violations += 2  # EMA cross è grave, conta doppio
            
            # B. Rottura strutturale
            body_close = close[-1]
            body_open = open_[-1]
            candle_close = min(body_close, body_open)
            reset_threshold = max(self.symbol.PipSize * 15, atr_current * 0.5)
            if candle_close < ema_slow_5m[-1] - reset_threshold:
                violations += 1
            
            # C. BBW espansione estrema
            if (bb_w_pct > 90 or bb_w_pct < 20 )and self.bbw_invalidated is False:
                self.bbw_invalidated = True
                violations += 1
            elif self.bbw_invalidated is True and (bb_w_pct < 85 and bb_w_pct > 25):
                self.bbw_invalidated = False               
                violations -= 1
            
            # Accumula violazioni
            if violations > 0:
                self._bias_violation_count += violations
            else:
                # Se tutto ok, riduci contatore (ma non sotto zero)
                self._bias_violation_count = max(0, self._bias_violation_count - 1)
            
            # Reset solo con violazioni persistenti
            if self._bias_violation_count >= 3:
                self.trend_bias = "NEUTRAL"
                self._bias_violation_count = 0
                self._bias_candle_count = 0
                self.bbw_invalidated = False
                api.Print("RESET BIAS LONG -> Violazioni accumulate")
                for order in api.PendingOrders:
                    if order.Label == "AdvancedBot" and order.TradeType == TradeType.Buy:
                        api.CancelPendingOrder(order)
                return
        
        # ==== LOGICA RESET SHORT ====
        elif self.trend_bias == "SHORT":
            violations = 0
            
            # A. EMA cross
            if ema_fast_5m[-1] > ema_slow_5m[-1] + ema_gap_threshold:
                violations += 2
            
            # B. Rottura strutturale
            body_close = close[-1]
            body_open = open_[-1]
            candle_close = max(body_close, body_open)
            reset_threshold = max(self.symbol.PipSize * 15, atr_current * 0.5)
            if candle_close > ema_slow_5m[-1] + reset_threshold:
                violations += 1
            
            # C. BBW espansione estrema
            if (bb_w_pct > 90 or bb_w_pct < 20) and self.bbw_invalidated is False:
                self.bbw_invalidated = True
                violations += 1
            elif self.bbw_invalidated is True and (bb_w_pct < 85 and bb_w_pct > 25):
                self.bbw_invalidated = False               
                violations -= 1
            
            if violations > 0:
                self._bias_violation_count += violations
            else:
                self._bias_violation_count = max(0, self._bias_violation_count - 1)
            
            if self._bias_violation_count >= 3:
                self.trend_bias = "NEUTRAL"
                self._bias_violation_count = 0
                self._bias_candle_count = 0
                self.bbw_invalidated = False
                api.Print("RESET BIAS SHORT -> Violazioni accumulate")
                for order in api.PendingOrders:
                    if order.Label == "AdvancedBot" and order.TradeType == TradeType.Sell:
                        api.CancelPendingOrder(order)
                return        
    # ======================================================
    # APERTURA POSIZIONE
    # ======================================================
    def OnPositionOpened(self, args):
        position = args.Position
        if position.SymbolName == self.symbol.Name and position.Label == "AdvancedBot":
            # L'ordine è entrato! Ora gestiamo la posizione.
            self.order_lock = True # Manteniamo il lock per non aprire altro
            self.last_entry_time = api.Server.Time
            # ========================================
            # CORREZIONE SL SE SLIPPAGE
            # ========================================           
            if hasattr(self, 'planned_entry_price') and hasattr(self, 'planned_sl_pips'):               
                entry_real = position.EntryPrice
                entry_planned = self.planned_entry_price
                sl_planned_pips = self.planned_sl_pips
                
                # Calcola slippage in pips
                if position.TradeType == TradeType.Buy:
                    slippage_pips = (entry_real - entry_planned) / self.symbol.PipSize
                else:
                    slippage_pips = (entry_planned - entry_real) / self.symbol.PipSize
                
                if abs(slippage_pips) > 9.5:
                    api.ClosePosition(position)
                    api.Print(f"(slippage: {slippage_pips:.1f}p)")
                    api.Print("TRADE ANNULLATO, SLIPPAGE ECCESSIVO")
                    # ===== 🆕 PAUSA 2 CANDELE =====
                    self.pause_bars_remaining = 2
                    api.Print(f"⏸️ PAUSA ATTIVATA: 2 candele (10 min)")
                    
                    # Reset lock
                    self.order_lock = False
                    return
                # === 🆕 CORREGGI SEMPRE SL/TP (NON SOLO SE SLIPPAGE) ===
                # Ricalcola basandosi su entry REALE
                if position.TradeType == TradeType.Buy:
                    new_sl_price = entry_real - (sl_planned_pips * self.symbol.PipSize)
                    new_tp_price = entry_real + (sl_planned_pips * self.rr * self.symbol.PipSize)
                else:
                    new_sl_price = entry_real + (sl_planned_pips * self.symbol.PipSize)
