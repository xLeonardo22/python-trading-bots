    def calc_volume(self, sl_pips, multiplier=1.0):
        """
        Compute position size using fixed-fractional risk management.

        Risk amount = min(Balance, Equity) * RISK_PCT * multiplier.
        Volume is floored to the broker's minimum step size.
        """
        try:
            capital            = min(self.account.Balance, self.account.Equity)
            effective_risk_pct = self.RISK_PCT * multiplier
            risk_amount        = capital * (effective_risk_pct / 100)
            pip_value_per_unit = self.symbol.PipValue / self.symbol.LotSize
            raw_volume         = risk_amount / (sl_pips * pip_value_per_unit)
            step               = self.symbol.VolumeInUnitsStep
            volume             = math.floor(max(raw_volume, self.symbol.VolumeInUnitsMin) / step) * step
            return max(int(volume), int(self.symbol.VolumeInUnitsMin))
        except Exception as e:
            api.Print(f"calc_volume ERROR: {e}")
            return 0

    def check_daily_stop_limit(self, max_stops):
        """
        Daily circuit breaker: blocks the bot after the first stop-loss of the day.
        Prevents revenge-trading and loss accumulation.
        Returns True if the limit has been reached, False otherwise.
        """
        today      = api.Server.Time.Date
        stops_today = sum(
            1 for h in api.History
            if h.SymbolName == self.symbol.Name
            and h.Label == "AdvancedBot"
            and h.ClosingTime.Date == today
            and h.NetProfit < 0)

        active = sum(
            1 for p in api.Positions
            if p.Label == "AdvancedBot" and p.SymbolName == self.symbol.Name)

        stops_today += active
        return stops_today >= max_stops

