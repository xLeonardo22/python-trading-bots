    # ===== INDICATORI CUSTOM =====
    def ema(self, values, period):
        # Versione ottimizzata per High-Frequency
        if len(values) < period: return [values[-1]] * len(values) if values else []
        # Fattore di decadimento
        alpha = 2.0 / (period + 1.0)   
        # Calcolo SMA iniziale per il primo punto
        sma_start = sum(values[:period]) / period   
        result = [sma_start]       
        # Calcolo iterativo veloce
        # Usiamo l'ultimo valore calcolato (result[-1]) per il prossimo
        for v in values[period:]:
            # Formula EMA: (Close - PrevEMA) * alpha + PrevEMA
            val = (v - result[-1]) * alpha + result[-1]
            result.append(val)           
        # Padding: Aggiungiamo zeri all'inizio per mantenere la lunghezza della lista originale
        # Così ema[-1] corrisponde a values[-1]
        return [0.0] * (period - 1) + result

    def ema_rsi(self, prices, period=14):
        if len(prices) < period + 1:
            return [None] * len(prices)
        # 1️⃣ calcolo delta
        deltas = []
        for i in range(1, len(prices)):
            deltas.append(prices[i] - prices[i - 1])
        # 2️⃣ separa gains / losses
        gains = [max(d, 0) for d in deltas]
        losses = [max(-d, 0) for d in deltas]
        # 3️⃣ EMA helper
        def ema(values, period):
            ema_vals = [None] * len(values)
            k = 2 / (period + 1)
            # inizializzazione con SMA
            sma = sum(v for v in values[:period] if v is not None) / period
            ema_vals[period - 1] = sma
            for i in range(period, len(values)):
                if ema_vals[i - 1] is None:
                    ema_vals[i] = values[i]
                else:
                    ema_vals[i] = values[i] * k + ema_vals[i - 1] * (1 - k)
            return ema_vals
        ema_gain = ema(gains, period)
        ema_loss = ema(losses, period)
        # 4️⃣ RSI
        rsi = [None] * len(prices)
        for i in range(len(gains)):
            if ema_gain[i] is None or ema_loss[i] is None:
                continue
            rs = ema_gain[i] / max(ema_loss[i], 1e-9)
            rsi[i + 1] = 100 - (100 / (1 + rs))
        # 5️⃣ fill iniziale neutro
        for i in range(len(rsi)):
            if rsi[i] is None:
                rsi[i] = 50
        return rsi

    def calcolo_atr(self, high, low, close, period=10):
        try:
            if len(high) < period + 1:
                return [None] * len(high)
            tr = []
            for i in range(1, len(high)):
                tr.append(
                    max(
                        high[i] - low[i],
                        abs(high[i] - close[i-1]),
                        abs(low[i] - close[i-1])))
            atr = [None] * period
            for i in range(period, len(tr)):
                atr.append(sum(tr[i-period:i]) / period)
            return atr
        except Exception as e:
            api.Print(f"Errore calcolo atr: {e}")
            return None

    def simple_reversal_long(self, open_, close, atr, ema_fast, ema_fast_5m):
