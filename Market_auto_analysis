    def ema(self, values, period):
        """
        Exponential Moving Average with SMA seed.
        Padding is added at the front so that ema[-1] aligns with values[-1].
        """
        if len(values) < period:
            return [values[-1]] * len(values) if values else []

        alpha     = 2.0 / (period + 1.0)
        sma_start = sum(values[:period]) / period
        result    = [sma_start]

        for v in values[period:]:
            result.append((v - result[-1]) * alpha + result[-1])

        return [0.0] * (period - 1) + result

    def ema_rsi(self, prices, period=14):
        """RSI computed with EMA smoothing (Wilder-style via EMA approximation)."""
        if len(prices) < period + 1:
            return [None] * len(prices)

        deltas = [prices[i] - prices[i - 1] for i in range(1, len(prices))]
        gains  = [max(d, 0) for d in deltas]
        losses = [max(-d, 0) for d in deltas]

        def _ema(values, period):
            result = [None] * len(values)
            k      = 2 / (period + 1)
            sma    = sum(v for v in values[:period] if v is not None) / period
            result[period - 1] = sma
            for i in range(period, len(values)):
                prev = result[i - 1] if result[i - 1] is not None else values[i]
                result[i] = values[i] * k + prev * (1 - k)
            return result

        ema_gain = _ema(gains, period)
        ema_loss = _ema(losses, period)

        rsi = [None] * len(prices)
        for i in range(len(gains)):
            if ema_gain[i] is None or ema_loss[i] is None:
                continue
            rs       = ema_gain[i] / max(ema_loss[i], 1e-9)
            rsi[i + 1] = 100 - (100 / (1 + rs))

        return [50 if v is None else v for v in rsi]

    def calc_atr(self, high, low, close, period=10):
        """Average True Range using simple rolling mean."""
        try:
            if len(high) < period + 1:
                return [None] * len(high)

            tr = [
                max(high[i] - low[i],
                    abs(high[i] - close[i - 1]),
                    abs(low[i]  - close[i - 1]))
                for i in range(1, len(high))
            ]

            atr = [None] * period
            for i in range(period, len(tr)):
                atr.append(sum(tr[i - period:i]) / period)

            return atr
        except Exception as e:
            api.Print(f"calc_atr ERROR: {e}")
            return None

    def calc_adx(self, high, low, close, period=14):
        """
        Wilder's ADX indicator.
        Measures trend strength independently of direction.
        Used as an entry filter: trade only when ADX is between 25 and 65,
        avoiding trendless and exhausted markets.
        Returns: (adx, plus_di, minus_di)
        """
        if len(close) < period * 2 + 1:
            return 0.0, 0.0, 0.0

        tr_list, plus_dm, minus_dm = [], [], []

        for i in range(1, len(close)):
            tr_list.append(max(
                high[i] - low[i],
                abs(high[i] - close[i - 1]),
                abs(low[i]  - close[i - 1])))

            up_move   = high[i] - high[i - 1]
            down_move = low[i - 1] - low[i]

            plus_dm.append(up_move   if up_move   > down_move and up_move   > 0 else 0.0)
            minus_dm.append(down_move if down_move > up_move   and down_move > 0 else 0.0)

        if len(tr_list) < period:
            return 0.0, 0.0, 0.0

        # Wilder smoothing initialisation
        atr_w      = sum(tr_list[:period])
        plus_dm_w  = sum(plus_dm[:period])
        minus_dm_w = sum(minus_dm[:period])

        dx_list = []
        plus_di = minus_di = 0.0

        for i in range(period, len(tr_list)):
            atr_w      = atr_w      - (atr_w      / period) + tr_list[i]
            plus_dm_w  = plus_dm_w  - (plus_dm_w  / period) + plus_dm[i]
            minus_dm_w = minus_dm_w - (minus_dm_w / period) + minus_dm[i]

            if atr_w == 0:
                continue

            plus_di  = (plus_dm_w  / atr_w) * 100
            minus_di = (minus_dm_w / atr_w) * 100
            di_sum   = plus_di + minus_di

            dx_list.append(0.0 if di_sum == 0 else abs(plus_di - minus_di) / di_sum * 100)

        if len(dx_list) < period:
            return 0.0, plus_di, minus_di

        adx = sum(dx_list[:period]) / period
        for dx_val in dx_list[period:]:
            adx = (adx * (period - 1) + dx_val) / period

        return adx, plus_di, minus_di

    def simple_reversal_long(self, open_, close, atr, ema_fast, ema_fast_5m):
        """
        Detect a bearish reversal signal for early exit on a long position.
        Requires at least 0.7R of open profit before triggering.
        """
        pos = self.get_position()
        if pos:
            risk     = abs(pos.EntryPrice - pos.StopLoss)
            if pos.StopLoss is None or risk == 0:
                return False
            profit_r = (self.symbol.Bid - pos.EntryPrice) / risk
            if profit_r < 0.7:
                return False

        # 1. Strong bearish candle (body > 1.5x 3-bar average)
        body_size = open_[-1] - close[-1]
        if body_size <= self.get_avg_body_size(open_, close, 3) * 1.5:
            return False

        # 2. Hurst deceleration (directional momentum fading)
        if len(close) >= 8:
            hurst_now  = self.get_fractal_efficiency(close,      10)
            hurst_prev = self.get_fractal_efficiency(close[:-3], 10)
            if hurst_prev > 0 and (hurst_now - hurst_prev) / hurst_prev < -0.20:
                api.Print(f"EARLY EXIT: Hurst decel {((hurst_now - hurst_prev) / hurst_prev):.2f}")
                return True

        # 3. Structural break below fast EMA
        if close[-1] < ema_fast_5m[-1] and close[-1] < min(close[-2], open_[-2]):
            api.Print("EARLY EXIT: Below EMA + prior low broken")
            return True

        return False

    def simple_reversal_short(self, open_, close, atr, ema_fast, ema_fast_5m):
        """
        Detect a bullish reversal signal for early exit on a short position.
        Requires at least 0.7R of open profit before triggering.
        """
        pos = self.get_position()
        if pos:
            risk     = abs(pos.EntryPrice - pos.StopLoss)
            if pos.StopLoss is None or risk == 0:
                return False
            profit_r = (pos.EntryPrice - self.symbol.Bid) / risk
            if profit_r < 0.7:
                return False

        # 1. Strong bullish candle
        body_size = close[-1] - open_[-1]
        if body_size <= self.get_avg_body_size(open_, close, 3) * 1.5:
            return False

        # 2. Hurst deceleration
        if len(close) >= 8:
            hurst_now  = self.get_fractal_efficiency(close,      10)
            hurst_prev = self.get_fractal_efficiency(close[:-3], 10)
            if hurst_prev > 0 and (hurst_now - hurst_prev) / hurst_prev < -0.20:
                api.Print(f"EARLY EXIT: Hurst decel {((hurst_now - hurst_prev) / hurst_prev):.2f}")
                return True

        # 3. Structural break above fast EMA
        if close[-1] > ema_fast_5m[-1] and close[-1] > max(close[-2], open_[-2]):
            api.Print("EARLY EXIT: Above EMA + prior high broken")
            return True

        return False

