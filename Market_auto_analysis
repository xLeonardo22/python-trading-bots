                api.Print(f"⏸️ PAUSA ATTIVATA: 2 candele dopo loss")
        else:
            # Su TP pulisci la zona (il prezzo si è spostato favorevolmente)
            self.last_loss_price_zone = None
            self.loss_zone_timestamp = None
        # 5. Pulizia dei Set di gestione 
        if hasattr(self, 'near_tp_reaches'):
            self.near_tp_reaches.discard(position.Id)           

        # 6. Controllo Circuit Breaker Giornaliero
        current_stops = self.check_daily_stop_limit(1)
