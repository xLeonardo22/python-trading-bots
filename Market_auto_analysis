    def get_monthly_status(self, profit_target_pct=5.0, soft_dd_pct=2.0, hard_dd_pct=4.0):
        """
        Monthly capital management system with three levels.

        Returns:
            0   — normal risk
            0.5 — recovery mode (risk halved; drawdown > soft_dd_pct)
            1   — profit lock (monthly target hit, then a losing trade)
            2   — hard stop (monthly loss > hard_dd_pct)

        Reset logic: if two consecutive take-profits occur during recovery mode,
        risk reverts to normal.
        """
        now           = api.Server.Time
        monthly_trades = sorted(
            [h for h in api.History
             if h.Label == "AdvancedBot"
             and h.ClosingTime.Month == now.Month
             and h.ClosingTime.Year  == now.Year],
            key=lambda x: x.ClosingTime)

        total_pnl     = sum(t.NetProfit for t in monthly_trades)
        start_balance = api.Account.Balance - total_pnl

        if start_balance <= 0:
            return 0

        current_pct = (total_pnl / start_balance) * 100.0

        # Hard stop
        if current_pct <= -hard_dd_pct:
            return 2

        # Profit lock: target reached, then a losing trade
        target_money = start_balance * (profit_target_pct / 100.0)
        tolerance    = start_balance * 0.002
        hit_target   = False
        running_pnl  = 0.0

        for t in monthly_trades:
            running_pnl += t.NetProfit
            if running_pnl >= target_money:
                hit_target = True
            if hit_target and t.NetProfit < -tolerance:
                return 1

        # Soft drawdown with reset check
        if current_pct <= -soft_dd_pct:
            if (len(monthly_trades) >= 2
                    and monthly_trades[-1].NetProfit > 0
                    and monthly_trades[-2].NetProfit > 0):
                return 0   # Two consecutive TPs — reset to normal risk
            return 0.5

        return 0

    def get_percentile(self, values, period):
        """Percentile rank of the current value within the last N periods."""
        if len(values) < period:
            return 50
        current = values[-1]
        window  = [values[-i] for i in range(1, period + 1)]
        return int(sum(1 for v in window if v <= current) / period * 100)

    def get_avg_body_size(self, open_, close, period):
        """Mean absolute candle body size over the last N bars."""
        if len(close) < period + 1:
            return 0.0
        return sum(abs(close[-i] - open_[-i]) for i in range(1, period + 1)) / period

    def get_volatility_percentile(self, atr, period=20):
        """Percentile rank of the current ATR value within the last N bars."""
        recent = [a for a in atr[-period:] if a is not None]
        if len(recent) < period:
            return 50
        return (sum(1 for v in recent if v <= recent[-1]) / period) * 100

    def get_fractal_efficiency(self, close, period=10):
        """
        Hurst Fractal Efficiency Index.

        Measures how directional a price move is relative to its total path length.
            1.0 → perfectly trending (straight line)
            0.0 → fully chaotic / sideways

        Conceptually analogous to efficiency metrics used in genomic sequence
        analysis to distinguish ordered from disordered regions.
        """
        net_displacement = abs(close[-1] - close[-period])
        path_length      = sum(abs(close[-i] - close[-i - 1]) for i in range(1, period + 1))
        return 0.0 if path_length == 0 else net_displacement / path_length

    def get_hurst_acceleration(self, close, period=10):
        """
        Rate of change of the Fractal Efficiency Index over 3 bars.
        Positive → directional momentum building.
        Negative → directional momentum fading.
        Typical output range: -0.20 to +0.20.
        """
        if len(close) < period + 3:
            return 0.0
        hurst_now  = self.get_fractal_efficiency(close,      period)
        hurst_prev = self.get_fractal_efficiency(close[:-3], period)
        return 0.0 if hurst_prev == 0 else hurst_now - hurst_prev

    def get_bollinger_squeeze(self, close, period=20, std_dev=2, pct_lookback=20):
        """
        Returns (%B, bandwidth, bandwidth_percentile).
        %B indicates where price sits within the Bollinger Band channel (0–100).
        Bandwidth measures channel width as a percentage of the SMA.
        Bandwidth percentile ranks current bandwidth against the last pct_lookback bars.
        """
        sma      = sum(close[-period:]) / period
        variance = sum((c - sma) ** 2 for c in close[-period:]) / period
        std      = math.sqrt(variance)
        upper    = sma + std * std_dev
        lower    = sma - std * std_dev

        percent_b = ((close[-1] - lower) / (upper - lower)) * 100 if upper != lower else 50
        bandwidth = ((upper - lower) / sma) * 100

        bbw_pct = 50
        if len(close) >= period + pct_lookback:
            bw_history = []
            for i in range(pct_lookback):
                offset = pct_lookback - 1 - i
                chunk  = close[-(period + offset): len(close) - offset] if offset > 0 else close[-period:]
                s      = sum(chunk) / period
                v      = sum((c - s) ** 2 for c in chunk) / period
                st     = math.sqrt(v)
                bw_history.append(((s + st * std_dev - (s - st * std_dev)) / s) * 100 if s != 0 else 0)

            bbw_pct = (sum(1 for bw in bw_history if bw <= bandwidth) / pct_lookback) * 100

        return percent_b, bandwidth, bbw_pct

    def get_quick_acceleration(self, close):
        """
        Short-term momentum acceleration over 3-bar windows.
        Compares the last 3-bar momentum to the preceding 3-bar momentum.
        Positive → accelerating; negative → decelerating.
        Typical range: -0.01 to +0.01.
        """
        if len(close) < 7:
            return 0.0
        momentum_now  = (close[-1] - close[-3]) / close[-3]
        momentum_prev = (close[-4] - close[-6]) / close[-6]
        return momentum_now - momentum_prev

