        for i in range(history_len - 1, -1, -1):
            trade = api.History[i]
            if trade.PositionId == position.Id:
                closed_trade = trade
                break                
        if not closed_trade:
            api.Print(f"⚠️ Errore Log: Trade {position.Id} non trovato in History.")
            return
        chiusura_effettiva = closed_trade.ClosingPrice
        pnl_reale = closed_trade.NetProfit
        # 3. Calcolo R-Multiple (Matematica blindata)
        r_mult = 0.0
        if position.StopLoss is not None:
            risk_price = abs(position.EntryPrice - position.StopLoss)
            if risk_price > 0:
                if position.TradeType == TradeType.Buy:
                    r_mult = (chiusura_effettiva - position.EntryPrice) / risk_price
                else:
                    r_mult = (position.EntryPrice - chiusura_effettiva) / risk_price

        # 4. LOG PROFESSIONALE CON ESITO NATIVO
        # args.Reason ti dirà esattamente: "StopLoss", "TakeProfit", "Closed" (chiuso a mercato dal bot), o "StopOut"
        esito_str = str(reason).upper()
        icona = "✅" if pnl_reale > 0 else "❌"
